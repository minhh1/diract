# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# playwright mcp debug artifacts
.playwright-mcp/

# perf test suite -- real session cookies/tokens, never commit
scripts/perf/auth-state.json

# client data export used to design the law firm template, never commit
/templatecustomtables-lawfirm/

# typescript
*.tsbuildinfo
next-env.d.ts
