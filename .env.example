# Copy to .env.local and fill in. See README.md.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google (Gmail integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# .doc -> .docx conversion microservice (docservice/). Vercel can't run
# LibreOffice in a serverless function -- deploy docservice/ to a host you
# control (Fly.io, Railway, a small VPS). Defaults to a local Docker
# container for dev (see lib/gotenberg.ts).
GOTENBERG_URL=http://localhost:3033

# Apache Guacamole gateway (virtual computers feature, see lib/guacamole.ts).
# Vercel can't run guacd/guacamole-client either -- deploy guacamole/ to a
# host you control, same as docservice/. See guacamole/README.md.
GUACAMOLE_URL=http://localhost:8080/guacamole
NEXT_PUBLIC_GUACAMOLE_URL=http://localhost:8080/guacamole
GUACAMOLE_JSON_SECRET_KEY=

# Cloud provider credentials (DigitalOcean/AWS/GCP) for BYO-billed virtual
# computers are NOT env vars -- each company's admin enters their own in
# Admin -> Virtual Computers, stored in company_cloud_credentials.

# Stripe subscription billing (platform-billed virtual computers, see
# lib/billing/plans.ts, supabase/company_subscriptions.sql). Redirect-only
# Checkout/Billing Portal flow -- no Stripe.js on the client, so no
# publishable key is needed.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PRO=

# Platform-owned cloud credentials for platform-billed virtual computers
# (the platform's own DO/AWS/GCP account -- distinct from each company's
# BYO company_cloud_credentials, see lib/vmProviders/platformCredentials.ts).
# Only DigitalOcean is provisionable so far (see lib/vmProviders/registry.ts).
DIGITALOCEAN_PLATFORM_API_TOKEN=
